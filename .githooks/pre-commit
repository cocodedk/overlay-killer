#!/bin/sh
set -eu

echo "Running pre-commit checks..."

for MANIFEST in chrome/manifest.json firefox/manifest.json; do
  if [ -f "$MANIFEST" ]; then
    python3 -m json.tool "$MANIFEST" > /dev/null 2>&1 || {
      echo "ERROR: $MANIFEST is invalid JSON" >&2
      exit 1
    }
    echo "✓ $MANIFEST is valid"
  fi
done

echo "Pre-commit checks passed."
